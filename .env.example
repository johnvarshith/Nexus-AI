# ==================== APP ====================
APP_NAME=NexusAI
DEBUG=true
ENV=development

# ==================== OLLAMA ====================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MAIN_MODEL=qwen2.5:3b
OLLAMA_CODER_MODEL=qwen2.5-coder:7b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_FAST_MODEL=qwen2.5:3b
OLLAMA_DEEP_MODEL=phi3:3.8b

# ==================== DATABASE ====================
# For local dev with Docker Postgres
DATABASE_URL=postgresql://nexusai:your_password_here@localhost:5432/nexusai_db
POSTGRES_USER=nexusai
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=nexusai_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ==================== CLOUD LLM (Optional) ====================
USE_CLOUD_LLM=False
OPENAI_API_KEY=your_key_here
GROQ_API_KEY=your_key_here

# ==================== API & MLFLOW ====================
MLFLOW_TRACKING_URI=http://localhost:5000
API_HOST=0.0.0.0
API_PORT=8000